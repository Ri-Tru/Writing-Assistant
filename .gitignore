# 编译输出目录（TypeScript 编译生成）
out/
dist/
build/

# Node.js 依赖
node_modules/

# 打包后的扩展文件（.vsix）
*.vsix

# 测试覆盖率报告
coverage/
.nyc_output/

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 操作系统生成文件
.DS_Store
Thumbs.db
desktop.ini

# VSCode 本地配置（个人偏好，不应共享）
.vscode-test/
.vscode/settings.json      # 如果包含用户特定设置
.vscode/tasks.json
# .vscode/launch.json      # 如果包含用户特定路径
.vscode/*.code-workspace   # 工作区文件通常不共享

# 临时文件
*.tmp
*.swp
*~
*.bak
tmp.*
temp.*

# 环境变量文件（通常包含密钥）
.env
.env.local
.env.*.local

# 扩展开发时生成的文件
*.vsixmanifest
*.vsix

# TypeScript 构建信息
tsconfig.tsbuildinfo